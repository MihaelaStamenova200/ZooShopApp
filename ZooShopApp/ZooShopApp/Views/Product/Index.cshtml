@if (User.Identity.IsAuthenticated && User.IsInRole("Administrator"))
{
    <div class="col-md-3 mb-4">
        <a asp-controller="Product"
           asp-action="Create"
           style="text-decoration:none;">

            <div class="card h-100 d-flex align-items-center justify-content-center"
                 style="border:2px dashed #ff4d8d; cursor:pointer;">

                <div class="text-center p-5">
                    <h1 style="color:#ff4d8d;">＋</h1>
                    <p class="fw-bold">Добави продукт</p>
                </div>

            </div>

        </a>
    </div>
}
<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-3 mb-4">
            <div class="card h-100 shadow-sm">

                <div class="position-relative">
                    <img src="@item.Picture" class="card-img-top" style="height:200px; object-fit:cover;" />

                    <a asp-controller="Favorite"
                       asp-action="Add"
                       asp-route-productId="@item.Id"
                       class="btn btn-light position-absolute"
                       style="top:10px; right:10px; border-radius:50%;">
                        ❤️
                    </a>
                </div>

                <div class="card-body text-center">

                    <h5>@item.ProductName</h5>

                    <p class="text-muted">@item.CategoryName</p>

                    @if (item.Discount > 0)
                    {
                        <p>
                            <span style="text-decoration:line-through;">
                                @item.Price.ToString("F2") eu.
                            </span>
                            <span class="text-success fw-bold">
                                @((item.Price - item.Price * item.Discount / 100).ToString("F2")) eu.
                            </span>
                        </p>
                    }
                    else
                    {
                        <p class="fw-bold">@item.Price.ToString("F2") eu.</p>
                    }

                </div>

                <div class="card-footer text-center">

                    <a asp-action="Details"
                       asp-route-id="@item.Id"
                       class="btn btn-outline-secondary w-100 mb-2">
                        Детайли
                    </a>

                    @if (this.User.Identity.IsAuthenticated)
                    {
                        <a asp-controller="Order"
                           asp-action="Create"
                           asp-route-id="@item.Id"
                           class="btn btn-success w-100 mb-2">
                            Поръчай
                        </a>
                    }

                    @if ((this.User.Identity.IsAuthenticated) && (this.User.IsInRole("Administrator")))
                    {
                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-warning w-100 mb-2">
                            Редактирай
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-danger w-100">
                            Изтрий
                        </a>
                    }

                </div>

            </div>
        </div>
    }
</div>