<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ZooShopApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ZooShopApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar custom-navbar">

            <div class="container-fluid d-flex justify-content-between align-items-center">

                <!-- ЛЯВО -->
                <div class="d-flex gap-3">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">Начало</a>
                    <a class="nav-link" asp-controller="Product" asp-action="Index">Продукти</a>
                </div>

                <!-- ЦЕНТЪР -->
                <a class="navbar-brand center-logo"
                   asp-controller="Home"
                   asp-action="Index">
                    🐾 ZooShopApp
                </a>

                <!-- ДЯСНО -->
                <div class="d-flex gap-3 align-items-center">

                    <a class="nav-link" asp-controller="Favorite" asp-action="MyFavorites">
                        ❤️ Любими
                    </a>

                    @if (this.User.Identity.IsAuthenticated)
                    {
                        <a class="nav-link" asp-controller="Order" asp-action="MyOrders">
                            📦 Поръчки
                        </a>
                    }

                    <a class="nav-link" asp-controller="Home" asp-action="Contacts">
                        📞 Контакти
                    </a>

                    @if (this.User.Identity.IsAuthenticated && this.User.IsInRole("Administrator"))
                    {
                        <div class="dropdown">
                            <button class="btn btn-light dropdown-toggle"
                                    data-bs-toggle="dropdown">
                                Админ
                            </button>

                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/Client/Index">Клиенти</a></li>
                                <li><a class="dropdown-item" href="/Order/Index">Поръчки</a></li>
                                <li><a class="dropdown-item" href="/Statistic/Index">Статистики</a></li>
                            </ul>
                        </div>
                    }

                    <partial name="_LoginPartial" />

                </div>

            </div>

        </nav>
    </header>
  
        <main class="container">
            @RenderBody()
        </main>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
