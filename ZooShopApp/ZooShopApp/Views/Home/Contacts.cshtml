@{
    ViewData["Title"] = "Contacts";
}

<h2 class="text-center mb-5">📞 Свържи се с нас</h2>

<div class="row">

    <!-- ЛЯВА ЧАСТ -->
    <div class="col-md-5">

        <div class="contact-info p-4">

            <h4>📍 Адрес</h4>
            <p>гр. София, България</p>

            <h4>📧 Имейл</h4>
            <p>zooshop@email.com</p>

            <h4>📞 Телефон</h4>
            <p>+359 888 123 456</p>

        </div>

    </div>

    <!-- ДЯСНА ЧАСТ -->
    <div class="col-md-7">

        <form class="contact-form p-4">

            <div class="mb-3">
                <label>Име</label>
                <input type="text" class="form-control" placeholder="Вашето име">
            </div>

            <div class="mb-3">
                <label>Имейл</label>
                <input type="email" class="form-control" placeholder="Вашият имейл">
            </div>

            <div class="mb-3">
                <label>Съобщение</label>
                <textarea class="form-control" rows="5" placeholder="Напишете съобщение..."></textarea>
            </div>

            <button class="btn btn-primary w-100">
                Изпрати
            </button>

        </form>

    </div>

</div>
<div class="mt-5">
    <iframe src="https://www.google.com/maps?q=Sofia&output=embed"
            width="100%"
            height="300"
            style="border:0; border-radius:15px;">
    </iframe>
</div>